{
  "name": "@batou.dev/bytes",
  "version": "0.5.1",
  "description": "Work with byte sizes in JavaScript with native Intl support",
  "license": "MIT",
  "author": "Vincent Batoufflet <vincent@batou.dev>",
  "keywords": [
    "binary",
    "bytes",
    "decimal",
    "format",
    "iec",
    "intl",
    "parse",
    "si"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vbatoufflet/js-bytes.git"
  },
  "bugs": {
    "url": "https://github.com/vbatoufflet/js-bytes/issues"
  },
  "homepage": "https://github.com/vbatoufflet/js-bytes#readme",
  "main": "dist/bytes.js",
  "module": "dist/bytes.es.js",
  "types": "types/index.d.ts",
  "sideEffects": false,
  "files": [
    "CHANGELOG.md",
    "dist/bytes.es.js",
    "dist/bytes.js",
    "README.md",
    "src",
    "types",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "rollup --config rollup.config.mjs",
    "docs": "typedoc types/index.d.ts",
    "lint": "eslint .",
    "release": "npm run --production build && npm publish",
    "test": "ts-mocha --paths tests/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@batou.dev/eslint-config": "^0.2.1",
    "@eslint/compat": "^2.0.5",
    "@rollup/plugin-commonjs": "^23.0.2",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/chai": "^4.2.16",
    "@types/mocha": "^10.0.0",
    "chai": "^4.3.4",
    "esbuild": "^0.15.13",
    "eslint": "^10.2.1",
    "eslint-plugin-perfectionist": "^5.9.0",
    "mocha": "^11.7.5",
    "rollup": "^2.79.1",
    "rollup-plugin-esbuild": "^4.0.1",
    "ts-mocha": "^11.1.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0"
  }
}
