{
  "compilerOptions": {
    "baseUrl": ".",
    "esModuleInterop": true,
    "ignoreDeprecations": "6.0",
    "lib": ["esnext"],
    "module": "commonjs",
    "moduleResolution": "node",
    "paths": {
      "@/*": ["./*"],
    },
    "rootDir": ".",
    "strict": true,
    "target": "esnext",
    "types": ["chai", "mocha"],
  },
  "exclude": ["node_modules"],
  "include": ["src/**/*.ts", "tests/**/*.ts", "types/**/*.d.ts"],
}
